<UserControl x:Class="LogViewerPro.WPF.Views.AIAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧工具面板 -->
        <materialDesign:Card Grid.Column="0" Margin="8" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 模型选择 -->
                <Border Grid.Row="0" Background="{DynamicResource PrimaryHueLightBrush}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="AI模型" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding AvailableModels}"
                                  SelectedItem="{Binding CurrentModel}"
                                  DisplayMemberPath="Name"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <materialDesign:PackIcon Kind="Speedometer" Width="16" Height="16" 
                                                     VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="响应时间: 2.5秒" FontSize="11" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 可用工具列表 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock Text="可用工具" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        
                        <ItemsControl>
                            <ItemsControl.Items>
                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ChartBar" Width="20"/>
                                        <TextBlock Text="分析日志" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Filter" Width="20"/>
                                        <TextBlock Text="筛选日志" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="SwapHorizontal" Width="20"/>
                                        <TextBlock Text="数据转换" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckCircle" Width="20"/>
                                        <TextBlock Text="数据校验" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Compare" Width="20"/>
                                        <TextBlock Text="数据对比" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Folder" Width="20"/>
                                        <TextBlock Text="项目分析" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </ItemsControl.Items>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- 会话操作 -->
                <StackPanel Grid.Row="2" Margin="8">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="History" Width="20"/>
                            <TextBlock Text="查看历史" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Delete" Width="20"/>
                            <TextBlock Text="清空会话" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- 右侧对话区域 -->
        <materialDesign:Card Grid.Column="1" Margin="8" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 对话历史 -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl>
                        <ItemsControl.Items>
                            <!-- AI消息 -->
                            <Border Background="{DynamicResource SecondaryHueMidBrush}" 
                                    CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                    HorizontalAlignment="Left" MaxWidth="600">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="Robot" Width="20"/>
                                        <TextBlock Text="AI助手" FontWeight="Bold" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="你好!我是LogViewer Pro的智能助手。我可以帮你分析日志、转换数据、分析项目等。有什么可以帮你的吗?"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- 用户消息 -->
                            <Border Background="{DynamicResource PrimaryHueMidBrush}"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                    HorizontalAlignment="Right" MaxWidth="600">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="你" FontWeight="Bold" Margin="0,0,8,0"/>
                                        <materialDesign:PackIcon Kind="Account" Width="20"/>
                                    </StackPanel>
                                    <TextBlock Text="帮我分析一下最近的错误日志" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- AI响应 -->
                            <Border Background="{DynamicResource SecondaryHueMidBrush}"
                                    CornerRadius="8" Padding="12" Margin="0,0,0,16"
                                    HorizontalAlignment="Left" MaxWidth="600">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <materialDesign:PackIcon Kind="Robot" Width="20"/>
                                        <TextBlock Text="AI助手" FontWeight="Bold" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="好的,我来分析最近的错误日志。发现以下问题:" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    
                                    <!-- 工具调用结果 -->
                                    <Border Background="{DynamicResource MaterialDesignBackground}"
                                            CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="📊 日志分析结果" FontWeight="Bold"/>
                                            <TextBlock Text="• 错误总数: 15条" Margin="0,4,0,0"/>
                                            <TextBlock Text="• 主要错误: 数据库连接超时" Margin="0,4,0,0"/>
                                            <TextBlock Text="• 建议: 检查数据库连接池配置" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ItemsControl.Items>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 输入区域 -->
                <Border Grid.Row="1" Background="{DynamicResource MaterialDesignCardBackground}" 
                        BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,1,0,0" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="输入消息... (按Enter发送)"
                                 TextWrapping="Wrap" AcceptsReturn="True" Height="60"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Button Grid.Column="1" Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="16,0,0,0" Height="60" Width="80">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="Send" Width="24" Height="24"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
