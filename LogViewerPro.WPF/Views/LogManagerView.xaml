<UserControl x:Class="LogViewerPro.WPF.Views.LogManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <materialDesign:Card Grid.Row="0" Padding="16" Margin="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20"/>
                            <TextBlock Text="打开日志" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                            <TextBlock Text="刷新" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="8,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Export" Width="20" Height="20"/>
                            <TextBlock Text="导出" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBox materialDesign:HintAssist.Hint="搜索日志" 
                             Width="250" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource MaterialDesignIconButton}">
                        <materialDesign:PackIcon Kind="Magnify" Width="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- 高级筛选面板 -->
        <materialDesign:Expander Grid.Row="1" Header="高级筛选" IsExpanded="True" Margin="8,8,8,0">
            <materialDesign:Card Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 筛选条件 -->
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="日志级别" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="DEBUG" Margin="0,0,8,0"/>
                            <CheckBox Content="INFO" IsChecked="True" Margin="0,0,8,0"/>
                            <CheckBox Content="WARN" IsChecked="True" Margin="0,0,8,0"/>
                            <CheckBox Content="ERROR" IsChecked="True" Margin="0,0,8,0"/>
                            <CheckBox Content="FATAL" IsChecked="True"/>
                        </StackPanel>

                        <TextBlock Text="关键字搜索" FontWeight="Bold" Margin="0,16,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="输入关键字"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                                <CheckBox Content="正则表达式" Margin="0,0,8,0"/>
                                <CheckBox Content="大小写敏感"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="16,0">
                        <TextBlock Text="时间范围" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <DatePicker Grid.Column="0" materialDesign:HintAssist.Hint="开始时间"/>
                            <TextBlock Grid.Column="1" Text="至" VerticalAlignment="Center" Margin="8,0"/>
                            <DatePicker Grid.Column="2" materialDesign:HintAssist.Hint="结束时间"/>
                        </Grid>

                        <TextBlock Text="来源过滤" FontWeight="Bold" Margin="0,16,0,8"/>
                        <ComboBox materialDesign:HintAssist.Hint="选择来源" IsEditable="True">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="ServiceA"/>
                            <ComboBoxItem Content="ServiceB"/>
                            <ComboBoxItem Content="ServiceC"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="16,0">
                        <TextBlock Text="行号范围" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="开始行"/>
                            <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" Margin="8,0"/>
                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="结束行"/>
                        </Grid>

                        <TextBlock Text="排除模式" FontWeight="Bold" Margin="0,16,0,8"/>
                        <TextBox materialDesign:HintAssist.Hint="输入排除关键字(多个用逗号分隔)"/>
                    </StackPanel>

                    <!-- 操作按钮 -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Bottom" Margin="16,0,0,0">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Filter" Width="20"/>
                                <TextBlock Text="应用筛选" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Clear" Width="20"/>
                                <TextBlock Text="清除筛选" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave" Width="20"/>
                                <TextBlock Text="保存筛选" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </materialDesign:Expander>

        <!-- 日志列表 -->
        <DataGrid Grid.Row="2" Margin="8" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="{DynamicResource MaterialDesignDivider}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="行号" Binding="{Binding LineNumber}" Width="80"/>
                <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160"/>
                <DataGridTemplateColumn Header="级别" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Level, Converter={StaticResource LevelToColorConverter}}"
                                    CornerRadius="4" Padding="8,4">
                                <TextBlock Text="{Binding Level}" FontWeight="Bold" 
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="150"/>
                <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 统计面板 -->
        <materialDesign:Card Grid.Row="3" Padding="16" Margin="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#4CAF50" CornerRadius="4" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="INFO" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="1,234" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FF9800" CornerRadius="4" Padding="12,8" Margin="8,0">
                        <StackPanel>
                            <TextBlock Text="WARN" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="89" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F44336" CornerRadius="4" Padding="12,8" Margin="8,0">
                        <StackPanel>
                            <TextBlock Text="ERROR" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="15" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#9C27B0" CornerRadius="4" Padding="12,8" Margin="8,0">
                        <StackPanel>
                            <TextBlock Text="FATAL" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="2" FontSize="16" FontWeight="Bold" Foreground="White"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="总计: 1,340 条日志" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontSize="16" FontWeight="Bold"/>

                <Button Grid.Column="2" Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartBar" Width="20"/>
                        <TextBlock Text="查看统计图表" Margin="8,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
